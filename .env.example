DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=
MNEMOS_ADMIN_USER_IDS=
MNEMOS_ALLOW_DISCORD_ADMINS=true
MNEMOS_STATE_PATH=.mnemos/state.db

OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o
MAX_CONTEXT_MESSAGES=20 # How many messages the model gets as context
MAX_COMPLETION_TOKENS=1024
TEMPERATURE=0.7

# Optional - leave blank to disable web_search and read_url tools
EXA_API_KEY=
